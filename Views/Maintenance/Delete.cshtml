@model TransportationManagement.Models.MaintenanceRecord
@{ ViewData["Title"] = "Delete Maintenance Record"; }
<div class="page-header"><h2><i class="fas fa-trash"></i> Delete Maintenance Record</h2></div>
<div class="card form-card">
    <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Delete service record: <strong>@Model.serviceType</strong> on @Model.serviceDate.ToString("dd MMM yyyy")?</div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="maintenanceId" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
