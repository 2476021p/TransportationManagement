@model IEnumerable<TransportationManagement.Models.Trip>
@{ ViewData["Title"] = "All Trips (Admin)"; }
<div class="page-header">
    <h2><i class="fas fa-route"></i> All Trips</h2>
    <a asp-controller="Trip" asp-action="CreateTrip" class="btn btn-primary"> New Trip</a>
</div>
<div class="card">
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Origin</th><th>Destination</th><th>Vehicle</th><th>Driver</th><th>Status</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var t in Model){
            <tr>
                <td>@i++</td>
                <td>@t.origin</td>
                <td>@t.destination</td>
                <td>@(t.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@(t.Driver?.name ?? "-")</td>
                <td><span class="badge badge-@(t.tripStatus==TripStatus.COMPLETED?"success":t.tripStatus==TripStatus.IN_PROGRESS?"warning":"info")">@t.tripStatus</span></td>
            </tr>
        }
        @if(!Model.Any()){<tr><td colspan="6" class="text-center">No trips found.</td></tr>}
        </tbody>
    </table>
</div>
