@model TransportationManagement.Models.Driver
@{ ViewData["Title"] = "Delete Driver"; }
<div class="page-header"><h2><i class="fas fa-trash"></i> Delete Driver</h2></div>
<div class="card form-card">
    <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Delete driver <strong>@Model.name</strong>?</div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="driverId" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
