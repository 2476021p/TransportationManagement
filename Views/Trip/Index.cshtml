@model IEnumerable<TransportationManagement.Models.Trip>
@{ ViewData["Title"] = "Trips"; }
<div class="page-header">
    <h2><i class="fas fa-route"></i> Trip Scheduling</h2>
    @if(User.IsInRole("Admin") || User.IsInRole("FleetManager")){
    <a asp-action="CreateTrip" class="btn btn-primary"><i class="fas fa-plus"></i> New Trip</a>
    }
</div>
<div class="card">
    <div class="table-search"><input type="text" id="searchInput" class="form-control" placeholder="Search trips..." onkeyup="searchTable()" /></div>
    <table class="table table-hover" id="mainTable">
        <thead><tr><th>#</th><th>Origin</th><th>Destination</th><th>Vehicle</th><th>Driver</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var t in Model){
            <tr>
                <td>@i</td>
                <td>@t.origin</td>
                <td>@t.destination</td>
                <td>@(t.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@(t.Driver?.name ?? "-")</td>
                <td><span class="badge badge-@(t.tripStatus==TripStatus.COMPLETED?"success":t.tripStatus==TripStatus.IN_PROGRESS?"warning":"info")">@t.tripStatus</span></td>
                <td class="action-btns">
                    <a asp-action="GetTripPlan" asp-route-id="@t.tripId" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                    <a asp-action="UpdateTripStatus" asp-route-id="@t.tripId" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                    @if(User.IsInRole("Admin") || User.IsInRole("FleetManager")){
                    <a asp-action="Delete" asp-route-id="@t.tripId" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                    }
                </td>
            </tr>
        }
        @if(!Model.Any()){<tr><td colspan="7" class="text-center empty-row">No trips found.</td></tr>}
        </tbody>
    </table>
</div>
@section Scripts{<script>function searchTable(){const q=document.getElementById('searchInput').value.toLowerCase();document.querySelectorAll('#mainTable tbody tr').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q)?'':'none';});}</script>}
