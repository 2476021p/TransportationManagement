@model TransportationManagement.Models.Driver
@{ ViewData["Title"] = "Edit Driver"; }
<div class="page-header">
    <h2><i class="fas fa-edit"></i> Edit Driver</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card form-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="driverId" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="name">Name</label>
                <input asp-for="name" class="form-control" />
                <span asp-validation-for="name" class="field-error"></span>
            </div>
            <div class="form-group col-6">
                <label asp-for="licenseNumber">License Number</label>
                <input asp-for="licenseNumber" class="form-control" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="contactNumber">Contact Number</label>
                <input asp-for="contactNumber" class="form-control" />
            </div>
            <div class="form-group col-6">
                <label asp-for="status">Status</label>
                <select asp-for="status" class="form-control" asp-items="Html.GetEnumSelectList<TransportationManagement.Models.DriverStatus>()"></select>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Driver</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
