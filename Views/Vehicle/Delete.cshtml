@model TransportationManagement.Models.Vehicle
@{ ViewData["Title"] = "Delete Vehicle"; }
<div class="page-header">
    <h2><i class="fas fa-trash"></i> Delete Vehicle</h2>
</div>
<div class="card form-card">
    <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete vehicle <strong>@Model.vehicleNumber</strong>?</div>
    <div class="detail-row"><span class="detail-label">Model</span><span class="detail-value">@Model.model</span></div>
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value">@Model.status</span></div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="vehicleId" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
