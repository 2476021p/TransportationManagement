@model IEnumerable<TransportationManagement.ViewModels.UserWithRoleViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-header">
    <h2>System Users</h2>
    <a asp-action="CreateUser" class="btn btn-primary"><i class="fas fa-plus"></i> Add User</a>
</div>

<div class="card">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ int i = 1; }
            @foreach (var user in Model)
            {
                <tr>
                    <td>@i++</td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td><span class="badge badge-role">@user.Role</span></td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-warning"> Edit</a>
                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Delete this user?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger"> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center">No users found.</td></tr>
            }
        </tbody>
    </table>
</div>
