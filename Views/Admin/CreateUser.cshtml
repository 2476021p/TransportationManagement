@model TransportationManagement.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Create User";
}

<div class="page-header">
    <h2><i class="fas fa-user-plus">

    </i> Create New User</h2>
    <a asp-action="Users" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card form-card">
    <form asp-action="CreateUser" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>
            <div class="form-group col-6">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="Email Address" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Password (min 6 chars)" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <div class="form-group col-6">
                <label asp-for="Role"></label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="form-control">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create User</button>
            <a asp-action="Users" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
