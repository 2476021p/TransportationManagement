@model IEnumerable<TransportationManagement.Models.FuelEntry>
@{ ViewData["Title"] = "Fuel Report"; }
<div class="page-header">
    <h2><i class="fas fa-file-alt"></i> Fuel Consumption Report</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card">
    <div class="report-summary">
        <div class="report-stat"><strong>Total Entries</strong><span>@Model.Count()</span></div>
        <div class="report-stat"><strong>Total Fuel (L)</strong><span>@Model.Sum(f => f.fuelQuantity).ToString("F2")</span></div>
        <div class="report-stat"><strong>Total Cost (₹)</strong><span>₹@Model.Sum(f => f.fuelCost).ToString("F2")</span></div>
    </div>
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Vehicle</th><th>Quantity (L)</th><th>Cost (₹)</th><th>Odometer</th><th>Date</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var f in Model){
            <tr>
                <td>@i++</td>
                <td>@(f.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@f.fuelQuantity</td>
                <td>₹@f.fuelCost</td>
                <td>@f.odometerReading km</td>
                <td>@f.entryDate.ToString("dd MMM yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
