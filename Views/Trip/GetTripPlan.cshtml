@model TransportationManagement.Models.Trip
@{ ViewData["Title"] = "Trip Plan"; }
<div class="page-header">
    <h2><i class="fas fa-route"></i> Trip Plan Details</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card detail-card">
    <div class="detail-row"><span class="detail-label">Trip ID</span><span class="detail-value">@Model.tripId</span></div>
    <div class="detail-row"><span class="detail-label">Vehicle</span><span class="detail-value">@(Model.Vehicle?.vehicleNumber ?? "-") - @(Model.Vehicle?.model ?? "")</span></div>
    <div class="detail-row"><span class="detail-label">Driver</span><span class="detail-value">@(Model.Driver?.name ?? "-")</span></div>
    <div class="detail-row"><span class="detail-label">Origin</span><span class="detail-value">@Model.origin</span></div>
    <div class="detail-row"><span class="detail-label">Destination</span><span class="detail-value">@Model.destination</span></div>
    <div class="detail-row"><span class="detail-label">Planned Route</span><span class="detail-value">@(Model.plannedRoute ?? "Not specified")</span></div>
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-@(Model.tripStatus==TripStatus.COMPLETED?"success":Model.tripStatus==TripStatus.IN_PROGRESS?"warning":"info")">@Model.tripStatus</span></span></div>
    <div class="form-actions">
        @if (User.IsInRole("FleetManager"))
        {
            <a asp-action="UpdateTripStatus" asp-route-id="@Model.tripId" class="btn btn-warning"><i class="fas fa-edit"></i> Update Status</a>
        }
    </div>
</div>
