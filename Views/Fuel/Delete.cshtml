@model TransportationManagement.Models.FuelEntry
@{
    ViewData["Title"] = "Delete Fuel Entry";
}

<div class="page-header">
    <h2><i class="fas fa-trash"></i> Confirm Deletion</h2>
</div>

<div class="card form-card">
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-triangle"></i>
        Are you sure you want to delete the fuel record for
        <strong>@(Model.Vehicle?.vehicleNumber ?? "this vehicle")</strong>?
        <br />
        <strong>Details:</strong> @Model.fuelQuantity L filled on @Model.entryDate.ToString("dd MMM yyyy")
    </div>
    
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="fuelId" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Yes, Delete Permanently</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>