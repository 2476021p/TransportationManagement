@model TransportationManagement.Models.Trip
@{
    ViewData["Title"] = "Delete Trip";
}

<div class="page-header">
    <h2><i class="fas fa-trash"></i> Confirm Deletion</h2>
</div>

<div class="card form-card">
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete the trip from
        <strong>@Model.origin</strong> to <strong>@Model.destination</strong>?
        <br /><small>This will remove trip history permanently.</small>
    </div>
    
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="tripId" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>