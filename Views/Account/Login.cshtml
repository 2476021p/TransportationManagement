@model TransportationManagement.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Transportation Management</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-logo">
                @* <i class="fas fa-truck-moving"></i> *@
                <h2>Transportation Management</h2>
                <p>Smart Fleet Operational System</p>
            </div>
            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                <div class="form-group">
                    <label asp-for="Email"><i class="fas fa-envelope"></i> Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password"><i class="fas fa-lock"></i> Password</label>
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </form>
            @* @if (ViewBag.LoginSuccess != null)
            {
                <script>
                                alert("✔ Login Successful");
                </script>
            } *@
            @* <div class="login-hint">
                <small>Default Admin: admin@transport.com / Admin@123</small>
            </div> *@
        </div>
    </div>
</body>
</html>
