@model IEnumerable<TransportationManagement.Models.MaintenanceRecord>
@{ ViewData["Title"] = "Maintenance"; }
<div class="page-header">
    <h2><i class="fas fa-wrench"></i> Maintenance Scheduling</h2>
    @if (User.IsInRole("FleetManager"))
    {
        <a asp-action="ScheduleMaintenance" class="btn btn-primary">
            <i class="fas fa-plus"></i> Schedule Maintenance
        </a>
    }
</div>
<div class="card">
    <div class="table-search"><input type="text" id="searchInput" class="form-control" placeholder="Search records..." onkeyup="searchTable()" /></div>
    <table class="table table-hover" id="mainTable">
        <thead><tr><th>S.No</th><th>Vehicle</th><th>Service Type</th><th>Service Date</th><th>Remarks</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var m in Model){
            <tr>
                <td>@i</td>
                <td>@(m.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@m.serviceType</td>
                <td>@m.serviceDate.ToString("dd MMM yyyy")</td>
                <td>@(m.remarks ?? "-")</td>
                    <td>
                        <span class="badge badge-@(m.status == MaintenanceStatus.COMPLETED ? "success" : m.status == MaintenanceStatus.IN_SERVICE ? "warning" : "info")">@m.status</span>
                    </td>
                
                <td class="action-btns">
                        @if (User.IsInRole("FleetManager") || User.IsInRole("Maintainance"))
                        {
                    <a asp-action="UpdateServiceRecord" asp-route-id="@m.maintenanceId" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                    <a asp-action="Delete" asp-route-id="@m.maintenanceId" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        }
                </td>
            </tr>
        }
        @if(!Model.Any()){<tr><td colspan="6" class="text-center empty-row">No maintenance records found.</td></tr>}
        </tbody>
    </table>
</div>
@section Scripts{<script>function searchTable(){const q=document.getElementById('searchInput').value.toLowerCase();document.querySelectorAll('#mainTable tbody tr').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q)?'':'none';});}</script>}
