@model IEnumerable<TransportationManagement.Models.FuelEntry>
@{ ViewData["Title"] = "Fuel Consumption Report"; }

<style>
    .filter-card { background: #f8f9fa; border-radius: 10px; border: 1px solid #dee2e6; margin-bottom: 25px; }
    .report-stat-card { border-left: 4px solid #007bff; border-radius: 8px; transition: transform 0.2s; }
    .report-stat-card:hover { transform: translateY(-5px); }
    .stat-title { font-size: 0.9rem; color: #6c757d; font-weight: 600; text-transform: uppercase; }
    .stat-value { font-size: 1.5rem; font-weight: 700; color: #343a40; }
</style>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-chart-line text-primary"></i> Fuel Consumption Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Analytics
    </a>
</div>

<div class="card filter-card shadow-sm">
    <div class="card-body">
        <form method="get" class="row align-items-end">
            <div class="form-group col-md-4 mb-0">
                <label class="font-weight-bold"><i class="fas fa-truck-pickup"></i> Filter by Vehicle</label>
                <select name="vehicleId" class="form-control custom-select" onchange="this.form.submit()">
                    <option value="">-- View All Vehicles --</option>
                    @if (ViewBag.Vehicles != null)
                    {
                        foreach (var v in ViewBag.Vehicles)
                        {
                            <option value="@v.vehicleId" selected="@(Context.Request.Query["vehicleId"] == v.vehicleId.ToString() ? "selected" : null)">
                                @v.vehicleNumber (@v.model)
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                @if (!string.IsNullOrEmpty(Context.Request.Query["vehicleId"]))
                {
                    <a asp-action="GenerateFuelReport" class="btn btn-link text-danger p-0 mb-2">
                        <i class="fas fa-times-circle"></i> Clear Filter
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card report-stat-card shadow-sm p-3">
            <div class="stat-title">Total Logs</div>
            <div class="stat-value">@Model.Count() <small class="text-muted" style="font-size: 14px;">Records</small></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card report-stat-card shadow-sm p-3" style="border-left-color: #28a745;">
            <div class="stat-title">Total Fuel Consumed</div>
            <div class="stat-value">@Model.Sum(f => f.fuelQuantity).ToString("N2") <small class="text-muted" style="font-size: 14px;">Litres</small></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card report-stat-card shadow-sm p-3" style="border-left-color: #ffc107;">
            <div class="stat-title">Total Expenditure</div>
            <div class="stat-value">₹@Model.Sum(f => f.fuelCost).ToString("N2")</div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="fas fa-list text-muted"></i> Detailed Consumption Log</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="thead-light">
                <tr>
                    <th>S.No</th>
                    <th>Vehicle Details</th>
                    <th>Qty (L)</th>
                    <th>Cost (₹)</th>
                    <th>Odometer</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var f in Model)
                {
                    <tr>
                        <td class="font-weight-bold text-muted">@i++</td>
                        <td>
                            <span class="badge badge-info">@f.Vehicle?.vehicleNumber</span>
                            <div class="small text-muted">@f.Vehicle?.model</div>
                        </td>
                        <td class="font-weight-bold text-success">@f.fuelQuantity L</td>
                        <td>₹@f.fuelCost.ToString("N2")</td>
                        <td><i class="fas fa-tachometer-alt text-muted small"></i> @f.odometerReading.ToString("N0") km</td>
                        <td>@f.entryDate.ToString("dd MMM yyyy")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted">No fuel data found for the selected criteria.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>