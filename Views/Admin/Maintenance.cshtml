@model IEnumerable<TransportationManagement.Models.MaintenanceRecord>
@{ ViewData["Title"] = "All Maintenance (Admin)"; }
<div class="page-header">
    <h2><i class="fas fa-wrench"></i> All Maintenance Records</h2>
    <a asp-controller="Maintenance" asp-action="ScheduleMaintenance" class="btn btn-primary"> Schedule</a>
</div>
<div class="card">
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Vehicle</th><th>Service Type</th><th>Date</th><th>Remarks</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var m in Model){
            <tr>
                <td>@i++</td>
                <td>@(m.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@m.serviceType</td>
                <td>@m.serviceDate.ToString("dd MMM yyyy")</td>
                <td>@(m.remarks ?? "-")</td>
            </tr>
        }
        @if(!Model.Any()){<tr><td colspan="5" class="text-center">No records found.</td></tr>}
        </tbody>
    </table>
</div>
