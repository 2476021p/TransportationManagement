@model TransportationManagement.Models.FuelEntry
@{ ViewData["Title"] = "Add Fuel Entry"; }
<div class="page-header">
    <h2><i class="fas fa-plus-circle"></i> Add Fuel Entry</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card form-card">
    <form asp-action="AddFuelEntry" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="vehicleId">Vehicle</label>
                <select asp-for="vehicleId" asp-items="ViewBag.Vehicles" class="form-control"><option value="">-- Select Vehicle --</option></select>
                <span asp-validation-for="vehicleId" class="field-error"></span>
            </div>
            <div class="form-group col-6">
                <label asp-for="entryDate">Entry Date</label>
                <input asp-for="entryDate" type="date" class="form-control" />
                <span asp-validation-for="entryDate" class="field-error"></span>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-4">
                <label asp-for="fuelQuantity">Fuel Quantity (Litres)</label>
                <input asp-for="fuelQuantity" type="number" step="0.01" class="form-control" placeholder="e.g. 50.00" />
                <span asp-validation-for="fuelQuantity" class="field-error"></span>
            </div>
            <div class="form-group col-4">
                <label asp-for="fuelCost">Fuel Cost (₹)</label>
                <input asp-for="fuelCost" type="number" step="0.01" class="form-control" placeholder="e.g. 4500.00" />
                <span asp-validation-for="fuelCost" class="field-error"></span>
            </div>
            <div class="form-group col-4">
                <label asp-for="odometerReading">Odometer Reading (km)</label>
                <input asp-for="odometerReading" type="number" class="form-control" placeholder="e.g. 12500" />
                <span asp-validation-for="odometerReading" class="field-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Entry</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
