@model TransportationManagement.Models.MaintenanceRecord
@{
    ViewData["Title"] = "Update Service Record";
}
 
<div class="page-header">
    <h2><i class="fas fa-edit"></i> Update Service Record</h2>
    <a asp-action="Index" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>
 
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
 
<div class="card form-card">
    <form asp-action="UpdateServiceRecord"
          asp-route-id="@Model.maintenanceId"
          method="post">
        @Html.AntiForgeryToken()
        
        <input type="hidden" asp-for="maintenanceId" />
 
        <div class="mb-3">
            <!-- Vehicle Dropdown -->
            <label asp-for="vehicleId" class="form-label">
                Vehicle
            </label>
            <select asp-for="vehicleId"
                    asp-items="ViewBag.Vehicles"
                    class="form-control">
                <option value="">-- Select Vehicle --</option>
            </select>
            <span asp-validation-for="vehicleId"
                  class="text-danger"></span>
        </div>
 
        <div class="mb-3">
            <!-- Service Type -->
            <label asp-for="serviceType" class="form-label">
                Service Type
            </label>
            <input asp-for="serviceType"
                   class="form-control"
                   placeholder="e.g. Oil Change, Tyre Rotation" />
            <span asp-validation-for="serviceType"
                  class="text-danger"></span>
        </div>
 
        <div class="mb-3">
            <!-- Service Date -->
            <label asp-for="serviceDate" class="form-label">
                Service Date
            </label>
            <input asp-for="serviceDate"
                   type="date"
                   class="form-control" />
            <span asp-validation-for="serviceDate"
                  class="text-danger"></span>
        </div>
 
        <div class="mb-3">
            <!-- Status Dropdown -->
            <label asp-for="status" class="form-label">
                Status
            </label>
            <select asp-for="status" class="form-control">
                <option value="SCHEDULED">Scheduled</option>
                <option value="IN_SERVICE">In Service</option>
                <option value="COMPLETED">Completed</option>
            </select>
        </div>
 
        <div class="mb-3">
            <!-- Remarks -->
            <label asp-for="remarks" class="form-label">
                Remarks
            </label>
            <input asp-for="remarks"
                   class="form-control"
                   placeholder="Optional notes" />
        </div>
 
        <div class="d-flex justify-content-between mt-3">
            <a asp-action="Index"
               class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Update
            </button>
        </div>
    </form>
</div>
 