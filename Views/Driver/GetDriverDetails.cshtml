@model TransportationManagement.Models.Driver
@{ ViewData["Title"] = "Driver Details"; }
<div class="page-header">
    <h2><i class="fas fa-id-card"></i> Driver Details</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card detail-card">
    <div class="detail-row"><span class="detail-label">Driver ID</span><span class="detail-value">@Model.driverId</span></div>
    <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">@Model.name</span></div>
    <div class="detail-row"><span class="detail-label">License Number</span><span class="detail-value">@Model.licenseNumber</span></div>
    <div class="detail-row"><span class="detail-label">Contact</span><span class="detail-value">@Model.contactNumber</span></div>
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-@(Model.status==DriverStatus.AVAILABLE?"success":Model.status==DriverStatus.ON_TRIP?"warning":"danger")">@Model.status</span></span></div>
    <div class="form-actions">
        <a asp-action="Edit" asp-route-id="@Model.driverId" class="btn btn-warning"><i class="fas fa-edit"></i> Edit</a>
        <a asp-action="GetAssignedTrips" asp-route-id="@Model.driverId" class="btn btn-primary"><i class="fas fa-route"></i> View Trips</a>
    </div>
</div>
