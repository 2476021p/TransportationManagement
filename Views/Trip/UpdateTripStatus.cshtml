@model TransportationManagement.Models.Trip
@{
    ViewData["Title"] = "Update Trip Status";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-edit"></i> Update Trip Management</h4>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="UpdateTripStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="tripId" />

                <div class="row">
                    <div class="form-group col-md-6 mb-3">
                        <label>Vehicle</label>
                        <select asp-for="vehicleId" asp-items="ViewBag.Vehicles" class="form-control"></select>
                    </div>
                    <div class="form-group col-md-6 mb-3">
                        <label>Driver</label>
                        <select asp-for="driverId" asp-items="ViewBag.Drivers" class="form-control"></select>
                    </div>
                    <div class="form-group col-md-6 mb-3">
                        <label>Origin</label>
                        <input asp-for="origin" class="form-control" />
                    </div>
                    <div class="form-group col-md-6 mb-3">
                        <label>Destination</label>
                        <input asp-for="destination" class="form-control" />
                    </div>
                    <div class="form-group col-md-6 mb-3">
                        <label>Trip Status</label>
                        <select asp-for="tripStatus" class="form-control"
                                asp-items="Html.GetEnumSelectList<TransportationManagement.Models.TripStatus>()">
                        </select>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>