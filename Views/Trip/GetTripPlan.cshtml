@model TransportationManagement.Models.Trip
@{
    ViewData["Title"] = "Trip Details";
}

<div class="page-header">
    <h2><i class="fas fa-route"></i> Trip Details</h2>
    <a asp-action="Index" class="btn btn-outline">Back</a>
</div>

<div class="card detail-card">
    <div class="detail-row"><span class="detail-label">Origin:</span> @Model.origin</div>
    <div class="detail-row"><span class="detail-label">Destination:</span> @Model.destination</div>
    <div class="detail-row"><span class="detail-label">Vehicle:</span> @(Model.Vehicle?.vehicleNumber ?? "N/A")</div>
    <div class="detail-row"><span class="detail-label">Driver:</span> @(Model.Driver?.name ?? "N/A")</div>
    <div class="detail-row"><span class="detail-label">Status:</span> @Model.tripStatus</div>

    <div class="form-actions mt-4">
        @if (User.IsInRole("FleetManager"))
        {
            <a asp-action="UpdateTripStatus" asp-route-id="@Model.tripId" class="btn btn-warning">Edit Status</a>
            <a asp-action="Delete" asp-route-id="@Model.tripId" class="btn btn-danger">Delete</a>
        }
    </div>
</div>