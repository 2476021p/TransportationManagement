@model TransportationManagement.Models.FuelEntry
@{ ViewData["Title"] = "Edit Fuel Entry"; }
<div class="page-header">
    <h2><i class="fas fa-edit"></i> Edit Fuel Entry</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card form-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="fuelId" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="vehicleId">Vehicle</label>
                <select asp-for="vehicleId" asp-items="ViewBag.Vehicles" class="form-control"></select>
            </div>
            <div class="form-group col-6">
                <label asp-for="entryDate">Entry Date</label>
                <input asp-for="entryDate" type="date" class="form-control" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-4">
                <label asp-for="fuelQuantity">Fuel Quantity (L)</label>
                <input asp-for="fuelQuantity" type="number" step="0.01" class="form-control" />
            </div>
            <div class="form-group col-4">
                <label asp-for="fuelCost">Fuel Cost (₹)</label>
                <input asp-for="fuelCost" type="number" step="0.01" class="form-control" />
            </div>
            <div class="form-group col-4">
                <label asp-for="odometerReading">Odometer (km)</label>
                <input asp-for="odometerReading" type="number" class="form-control" />
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
