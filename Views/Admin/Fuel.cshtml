@model IEnumerable<TransportationManagement.Models.FuelEntry>
@{ ViewData["Title"] = "All Fuel Entries (Admin)"; }
<div class="page-header">
    <h2><i class="fas fa-gas-pump"></i> All Fuel Entries</h2>
    <a asp-controller="Fuel" asp-action="AddFuelEntry" class="btn btn-primary"> Add Entry</a>
</div>
<div class="card">
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Vehicle</th><th>Quantity (L)</th><th>Cost</th><th>Odometer</th><th>Date</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var f in Model){
            <tr>
                <td>@i++</td>
                <td>@(f.Vehicle?.vehicleNumber ?? "-")</td>
                <td>@f.fuelQuantity</td>
                <td>₹@f.fuelCost</td>
                <td>@f.odometerReading km</td>
                <td>@f.entryDate.ToString("dd MMM yyyy")</td>
            </tr>
        }
        @if(!Model.Any()){<tr><td colspan="6" class="text-center">No fuel entries found.</td></tr>}
        </tbody>
    </table>
</div>
