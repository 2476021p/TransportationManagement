@model TransportationManagement.Models.Driver
@{ ViewData["Title"] = "Add Driver"; }
<div class="page-header">
    <h2> Add New Driver</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card form-card">
    <form asp-action="AddDriver" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="name">Name</label>
                <input asp-for="name" class="form-control" placeholder="Driver Full Name" />
                <span asp-validation-for="name" class="field-error"></span>
            </div>
            <div class="form-group col-6">
                <label asp-for="licenseNumber">License Number</label>
                <input asp-for="licenseNumber" class="form-control" placeholder="e.g. TN0120230001234" />
                <span asp-validation-for="licenseNumber" class="field-error"></span>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="contactNumber">Contact Number</label>
                <input asp-for="contactNumber" class="form-control" placeholder="e.g. 9876543210" />
                <span asp-validation-for="contactNumber" class="field-error"></span>
            </div>

            <div class="form-group col-6">
                <label>Email</label>
                <input name="email" class="form-control" placeholder="Enter Email" />
            </div>
 
            <div class="form-group col-6">
                <label>Password</label>
                <input name="password" type="password" class="form-control" placeholder="Enter Password" />
            </div>
 
            <div class="form-group col-6">
                <label asp-for="status">Status</label>
                <select asp-for="status" class="form-control" asp-items="Html.GetEnumSelectList<TransportationManagement.Models.DriverStatus>()"></select>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Driver</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
