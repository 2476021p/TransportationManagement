@model TransportationManagement.Models.Vehicle
 
@{
    ViewData["Title"] = "Delete Vehicle";
}
 
<div class="container mt-4">
    <h2 class="text-danger">Delete Vehicle</h2>
 
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
 
    <div class="card shadow-sm">
        <div class="card-body">
            <h4>Are you sure you want to delete this vehicle?</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Vehicle Number</dt>
                <dd class="col-sm-9">@Model.vehicleNumber</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.status</dd>
            </dl>
 
            <form method="post"
                  asp-controller="Vehicle"
                  asp-action="Delete"
                  asp-route-id="@Model.vehicleId">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
 