@model IEnumerable<TransportationManagement.Models.MaintenanceRecord>
@{ ViewData["Title"] = "Maintenance History"; }
<div class="page-header">
    <h2><i class="fas fa-history"></i> Maintenance History</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card">
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Service Type</th><th>Date</th><th>Remarks</th></tr></thead>
        <tbody>
        @{ int i=1; }
        @foreach(var m in Model){
            <tr><td>@i++</td><td>@m.serviceType</td><td>@m.serviceDate.ToString("dd MMM yyyy")</td><td>@(m.remarks??"-")</td></tr>
        }
        @if(!Model.Any()){<tr><td colspan="4" class="text-center empty-row">No maintenance history found.</td></tr>}
        </tbody>
    </table>
</div>
