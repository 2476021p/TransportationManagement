@model TransportationManagement.Models.FuelEntry
@{
    ViewData["Title"] = "Add Fuel Entry";
}

<div class="page-header">
    <h2><i class="fas fa-plus-circle"></i> Add Fuel Entry</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card form-card">
    <form asp-action="AddFuelEntry" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="vehicleId">Vehicle</label>
                <select asp-for="vehicleId" asp-items="ViewBag.Vehicles" class="form-control" required>
                    <option value="">-- Select Vehicle --</option>
                </select>
                <span asp-validation-for="vehicleId" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="entryDate">Entry Date</label>
                <input asp-for="entryDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="entryDate" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group col-md-4">
                <label asp-for="fuelQuantity">Quantity (Litres)</label>
                <input asp-for="fuelQuantity" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                <span asp-validation-for="fuelQuantity" class="text-danger"></span>
            </div>
            <div class="form-group col-md-4">
                <label asp-for="fuelCost">Total Cost (₹)</label>
                <input asp-for="fuelCost" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                <span asp-validation-for="fuelCost" class="text-danger"></span>
            </div>
            <div class="form-group col-md-4">
                <label asp-for="odometerReading">Odometer (km)</label>
                <input asp-for="odometerReading" type="number" class="form-control" placeholder="Current km" required />
                <span asp-validation-for="odometerReading" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions mt-3">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Entry</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>